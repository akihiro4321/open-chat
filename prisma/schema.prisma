generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Thread {
  id        String    @id @default(cuid())
  title     String    @default("新しいチャット")
  model     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id        String    @id @default(cuid())
  threadId  String
  requestId String?   @unique
  role      String
  content   String
  status    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  thread    Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  modelRun  ModelRun?
  agentRun  AgentRun?

  @@index([threadId, createdAt])
}

model ModelRun {
  id             String   @id @default(cuid())
  messageId      String   @unique
  model          String
  requestedModel String?
  fallbackUsed   Boolean  @default(false)
  inputTokens    Int?
  outputTokens   Int?
  totalTokens    Int?
  createdAt      DateTime @default(now())
  message        Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model RagIngestionRun {
  id                  String          @id @default(cuid())
  status              String
  sourcePath          String
  documentCount       Int             @default(0)
  chunkCount          Int             @default(0)
  chunkStrategy       String          @default("fixed")
  chunkSize           Int
  chunkOverlap        Int
  embeddingModel      String
  embeddingDimensions Int?
  lancedbUri          String
  tableName           String          @unique
  errorMessage        String?
  startedAt           DateTime        @default(now())
  completedAt         DateTime?
  documents           RagDocument[]
  chunks              RagChunk[]
  activeIndex         ActiveRagIndex?
}

model RagDocument {
  id             String          @id @default(cuid())
  ingestionRunId String
  sourcePath     String
  sourceName     String
  contentHash    String
  contentLength  Int
  createdAt      DateTime        @default(now())
  ingestionRun   RagIngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)
  chunks         RagChunk[]

  @@index([ingestionRunId])
  @@index([contentHash])
}

model RagChunk {
  id             String          @id @default(cuid())
  ingestionRunId String
  documentId     String
  sequence       Int
  startOffset    Int
  endOffset      Int
  text           String
  textHash       String
  createdAt      DateTime        @default(now())
  ingestionRun   RagIngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)
  document       RagDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, sequence])
  @@index([ingestionRunId])
  @@index([textHash])
}

model ActiveRagIndex {
  id             String          @id
  ingestionRunId String          @unique
  activatedAt    DateTime        @default(now())
  ingestionRun   RagIngestionRun @relation(fields: [ingestionRunId], references: [id], onDelete: Cascade)
}

model AgentRun {
  id                 String    @id @default(cuid())
  messageId          String    @unique
  status             String
  model              String
  maxIterations      Int
  currentIteration   Int
  currentInputJson   String
  toolCallsJson      String
  toolResultsJson    String
  pendingCallIdsJson String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  message            Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  toolCalls          ToolCall[]
}

model ToolCall {
  id         String    @id @default(cuid())
  agentRunId String
  callId     String
  name       String
  arguments  String
  output     String?
  isError    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  agentRun   AgentRun  @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  approval   Approval?

  @@index([agentRunId])
}

model Approval {
  id         String   @id @default(cuid())
  toolCallId String   @unique
  status     String
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  toolCall   ToolCall @relation(fields: [toolCallId], references: [id], onDelete: Cascade)
}
