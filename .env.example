OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=your_model_name_here
OPENAI_ALLOWED_MODELS=your_model_name_here,another_model_name
OPENAI_FALLBACK_MODEL=another_model_name
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# 任意: text-embedding-3系だけで使用できます
# OPENAI_EMBEDDING_DIMENSIONS=1536
# 任意: RAG索引の保存先と分割設定
RAG_LANCEDB_DIR=data/lancedb
RAG_CHUNK_STRATEGY=fixed
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=4
RAG_RETRIEVAL_MODE=hybrid
# 任意: エージェントループの最大反復回数
# AGENT_MAX_ITERATIONS=5
# 任意: マルチエージェントの役割別モデル。未指定時はスレッド選択モデルを使います
# AGENT_RESEARCH_MODEL=your_model_name_here
# AGENT_PLANNER_MODEL=your_model_name_here
# AGENT_SUPERVISOR_MODEL=your_model_name_here
